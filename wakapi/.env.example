# Wakapi environment variables
ENVIRONMENT=production
WAKAPI_LEADERBOARD_REQUIRE_AUTH=true
WAKAPI_DISABLE_LOCAL_AUTH=false

# Database configuration
WAKAPI_DB_PASSWORD=
WAKAPI_PASSWORD_SALT=

# Public URL of the Wakapi instance
WAKAPI_PUBLIC_URL=http://localhost:8080

# Mail configuration
WAKAPI_MAIL_ENABLED=false
WAKAPI_MAIL_SMTP_HOST=
WAKAPI_MAIL_SMTP_PORT=
WAKAPI_MAIL_SMTP_USER=
WAKAPI_MAIL_SMTP_PASS=
WAKAPI_MAIL_SENDER=
WAKAPI_MAIL_FROM=
WAKAPI_SUPPORT_CONTACT=

# Maximum number of database connections
WAKAPI_DB_MAX_CONNECTIONS=10

# GitLab OIDC Authentication
WAKAPI_GITLAB_CLIENT_ID=
WAKAPI_GITLAB_CLIENT_SECRET=
WAKAPI_OIDC_ALLOW_SIGNUP=false